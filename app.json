{
  "expo": {
    "name": "PRForgd",
    "slug": "prforgd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#001228"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prforgd.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "5"
    },
    "android": {
      "package": "com.prforgd.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#001228"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "PRForgd",
      "shortName": "PRForgd",
      "description": "Hero WOD tracker - track your times, PRs, and round splits",
      "backgroundColor": "#001228",
      "themeColor": "#001228"
    },
    "scheme": "prforgd",
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "cameraPermission": "PRForgd needs camera access to scan workouts.",
          "photosPermission": "PRForgd needs photo access to scan workouts."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9bfbbacf-ff3c-4087-8d5c-d85a69401283"
      }
    },
    "owner": "prcunningham"
  }
}
